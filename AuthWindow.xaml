<Window x:Class="APP_WPF_InstrumentControl.AuthWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:APP_WPF_InstrumentControl"
        mc:Ignorable="d"
        Background="Gray"
        ResizeMode="NoResize"
        Title="AuthWindow" Height="450" Width="600">
    <Grid>
        <Image Source="C:\Users\user\source\repos\APP_WPF_InstrumentControl\obj\Assets\аварийная лента.png" VerticalAlignment="Top" HorizontalAlignment="Center" Height="23" Width="800" ></Image>

        <TextBlock Text="Авторизация" FontSize="35" FontWeight="ExtraBold" HorizontalAlignment="Center" Margin="0,28,0,344" />

        <Label Content="Название фирмы" Margin="169,0,181,310" Width="250" Height="30" VerticalAlignment="Bottom" />
        <Border CornerRadius="20" Margin="0,0,0,275" Background="DarkGray" HorizontalAlignment="Center" Width="250" Height="35" VerticalAlignment="Bottom">
            <TextBox x:Name="TB_Name"  VerticalContentAlignment="Center" Background ="Transparent" BorderBrush="Transparent" ></TextBox>
        </Border>
        <Label Content="ИНН" Margin="175,159,175,0" Width="250" Height="30" VerticalAlignment="Top" />
        <Border CornerRadius="20" Margin="0,190,0,0" Background="DarkGray" HorizontalAlignment="Center" Width="250" Height="35" VerticalAlignment="Top">
            <TextBox x:Name="TB_INN"  VerticalContentAlignment="Center" Background ="Transparent" BorderBrush="Transparent" ></TextBox>
        </Border>
        <TextBlock Text="Выберите или введите адрес расположения инструмента" TextWrapping="Wrap" Margin="175,248,175,0" Width="250" Height="35" VerticalAlignment="Top" />
        
        <Border CornerRadius="20" Margin="0,283,0,0" Background="Transparent" HorizontalAlignment="Center" Width="250" Height="35" VerticalAlignment="Top">
            <ComboBox Background="DarkGray" x:Name="CB_address" DropDownOpened="CB_C" DataContext="CB_Address_Data" IsEditable="True" ></ComboBox>
        </Border>

        <Border CornerRadius="20" Margin="50,354,0,0" Background="red" HorizontalAlignment="Left" Width="200" Height="35" VerticalAlignment="Top">
            <Button x:Name="BT_Auth" Content="Войти" BorderBrush="Transparent" FontWeight="Medium" FontSize="18" Background="Transparent" Click="BT_Auth_Click"  ></Button>
        </Border>
        <Border CornerRadius="20" Margin="0,354,50,0" Background="red" HorizontalAlignment="Right" Width="200" Height="35" VerticalAlignment="Top">
            <Button x:Name="BT_Reg" Content="Зарегистрироваться" BorderBrush="Transparent" FontWeight="Medium" FontSize="18" Background="Transparent" Click="BT_Reg_Click"  ></Button>
        </Border>

        <Image Source="C:\Users\user\source\repos\APP_WPF_InstrumentControl\obj\Assets\аварийная лента.png" VerticalAlignment="Bottom" HorizontalAlignment="Center" Height="23" Width="800" ></Image>
    </Grid>
</Window>
