<Window x:Class="APP_WPF_InstrumentControl.MainMenu"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:APP_WPF_InstrumentControl"
        mc:Ignorable="d"
        Background="Gray"
        Title="MainMenu" Height="650" Width="820" BorderBrush="Transparent" ResizeMode="NoResize">
    <Grid>
        <Image Source="C:\Users\user\source\repos\APP_WPF_InstrumentControl\obj\Assets\аварийная лента.png" VerticalAlignment="Top" HorizontalAlignment="Center" Height="25" Width="850" />

        <TextBlock x:Name="TB_Head" Text="" FontSize="20" FontWeight="DemiBold" TextWrapping="Wrap" Margin="17,30,174,395"/>
        <Border CornerRadius="15" Margin="615,0,0,574" Background="Red" Height="30" Width="180" VerticalAlignment="Bottom" HorizontalAlignment="Left">
            <Button x:Name="BT_Auth" Background="Transparent"  BorderBrush="Transparent" Content="Сменить аккаунт" FontWeight="DemiBold" FontSize="16" Click="BT_Auth_Click" ></Button>
        </Border>

        <DataGrid x:Name="DG_Instruments" 
          SelectedCellsChanged="DG_SelectedInstrument"
         Height="300"
         Width="600"
         Background="White"
         RowBackground="White"
         AlternatingRowBackground="#F5F5F5"
         BorderBrush="Transparent"
         AutoGenerateColumns="False"
         
         IsReadOnly="True" Margin="0,107,110,0" VerticalAlignment="Top" HorizontalAlignment="Right">
            
            <DataGrid.Columns>
                <DataGridTextColumn Header="Название" Binding="{Binding Name}" Width="24*" Foreground="#424242">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="TextWrapping" Value="Wrap"/>
                            <Setter Property="MaxHeight" Value="60"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Категория" Binding="{Binding Category}" Width="24*"/>
                <DataGridTextColumn Header="Тип инструмента" Binding="{Binding Type}" Width="24*"/>
                <DataGridTextColumn Header="Инвентарный номер" Binding="{Binding Index}" Width="24*"/>
                <DataGridTemplateColumn Width="4*">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="X" 
                            Click="ButtonDeleteInstrument_Click"
                            Background="Transparent"
                            Foreground="#D32F2F"
                            BorderThickness="0"
                            FontWeight="Bold"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                
            </DataGrid.Columns>
        </DataGrid>

        <Label Content="Выберите категорию" Width="150" Height="30" Margin="0,0,610,173" VerticalAlignment="Bottom" HorizontalAlignment="Right"></Label>
        <ComboBox Name="CB_Category" Width="150" Height="30" Margin="0,0,610,150" VerticalAlignment="Bottom" HorizontalAlignment="Right"></ComboBox>
        <Label Content="Выберите тип" Width="150" Height="30" Margin="0,0,450,173" VerticalAlignment="Bottom" HorizontalAlignment="Right"></Label>
        <ComboBox Name="CB_Type" Width="150" Height="30" Margin="0,0,450,150" VerticalAlignment="Bottom" HorizontalAlignment="Right"></ComboBox>
        <Label Content="Выберите номер" Width="150" Height="30" Margin="0,0,290,173" VerticalAlignment="Bottom" HorizontalAlignment="Right"></Label>
        <ComboBox Name="CB_Index" Width="150" Height="30" Margin="0,0,290,150" VerticalAlignment="Bottom" HorizontalAlignment="Right"></ComboBox>

        <Button x:Name="BT_Filter" Content="ВЫБРАТЬ" FontWeight="Bold" Margin="615,0,0,150" Height="30" Width="120" Background="Orange" VerticalAlignment="Bottom" HorizontalAlignment="Left" Click="BT_Filter_Click"></Button>
        <Button x:Name="BT_ClearFilter" Content="X" FontWeight="Bold" Margin="735,0,0,150" Height="30" Width="30" Background="red" VerticalAlignment="Bottom" HorizontalAlignment="Left" Click="BT_ClearFilter_Click"></Button>

        <TextBox x:Name="TB_Name" GotFocus="TB_Name_GotFocus" LostFocus="TB_Name_LostFocus"
         Width="470" Height="30"
         Background="White"
         Foreground="#424242"
         FontSize="14"
         Padding="5"
         BorderThickness="0"
         Text="Название" Margin="0,0,290,89" VerticalAlignment="Bottom" HorizontalAlignment="Right"/>

        <TextBox x:Name="TB_Category" GotFocus="TB_Category_GotFocus" LostFocus="TB_Category_LostFocus"
         Width="150" Height="30"
         Background="White"
         Foreground="#424242"
         FontSize="14"
         Padding="5"
         BorderThickness="0"
         Margin="0,0,610,54"
         Text="Категория" VerticalAlignment="Bottom" HorizontalAlignment="Right"/>

        <TextBox x:Name="TB_Type" GotFocus="TB_Type_GotFocus" LostFocus="TB_Type_LostFocus"
         Width="150" Height="30"
         Background="White"
         Foreground="#424242"
         FontSize="14"
         Padding="5"
         BorderThickness="0"
         Margin="0,0,450,54"
         Text="Тип инструмента" VerticalAlignment="Bottom" HorizontalAlignment="Right"/>

        <TextBox x:Name="TB_Index" GotFocus="TB_Index_GotFocus" LostFocus="TB_Index_LostFocus"
         Width="150" Height="30"
         Background="White"
         Foreground="#424242"
         FontSize="14"
         Padding="5"
         BorderThickness="0"
         Margin="0,0,290,54"
         Text="Инвентарный номер" VerticalAlignment="Bottom" HorizontalAlignment="Right"/>

        <Button x:Name="BT_AddInstrument" Click="AddInstrument_Click" Content="ДОБАВИТЬ" FontWeight="Bold" Margin="615,0,0,54" Height="30" Width="150" Background="red" VerticalAlignment="Bottom" HorizontalAlignment="Left"></Button>
        <Button x:Name="BT_EditInstrument" Click="EditInstrument_Click" Content="ИЗМЕНИТЬ" FontWeight="Bold" Margin="615,0,0,89" Height="30" Width="150" VerticalAlignment="Bottom" HorizontalAlignment="Left"></Button>




        <Image Source="C:\Users\user\source\repos\APP_WPF_InstrumentControl\obj\Assets\аварийная лента.png" VerticalAlignment="Bottom" HorizontalAlignment="Center" Height="25" Width="850"  ></Image>
    </Grid>
</Window>
