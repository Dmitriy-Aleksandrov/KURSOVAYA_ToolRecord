<Window x:Class="APP_WPF_InstrumentControl.MainMenu"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:APP_WPF_InstrumentControl"
        mc:Ignorable="d"
        Background="Gray"
        Title="MainMenu" Height="550" Width="820" BorderBrush="Transparent" ResizeMode="NoResize">
    <Grid>
        <Image Source="C:\Users\user\source\repos\APP_WPF_InstrumentControl\obj\Assets\аварийная лента.png" VerticalAlignment="Top" HorizontalAlignment="Center" Height="25" Width="850" />

        <TextBlock x:Name="TB_Head" Text="" FontSize="20" FontWeight="DemiBold" TextWrapping="Wrap" Margin="17,30,174,395"/>
        <Border CornerRadius="15" Margin="609,0,0,467" Background="Red" Height="30" Width="180" VerticalAlignment="Bottom" HorizontalAlignment="Left">
            <Button x:Name="BT_Auth" Background="Transparent"  BorderBrush="Transparent" Content="Сменить аккаунт" FontWeight="DemiBold" FontSize="16" Click="BT_Auth_Click" ></Button>
        </Border>

        <DataGrid x:Name="DG_Instruments" 
          SelectedCellsChanged="DG_SelectedInstrument"
         Height="300"
         Width="600"
         Background="White"
         RowBackground="White"
         AlternatingRowBackground="#F5F5F5"
         BorderBrush="#BDBDBD"
         AutoGenerateColumns="False"
         IsReadOnly="True" Margin="100,92,100,142">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Название" Binding="{Binding Name}" Width="*" Foreground="#424242"/>
                <DataGridTextColumn Header="Категория" Binding="{Binding Category}" Width="*"/>
                <DataGridTextColumn Header="Тип инструмента" Binding="{Binding Type}" Width="*"/>
                <DataGridTextColumn Header="Инвентарный номер" Binding="{Binding Index}" Width="*"/>
                <DataGridTemplateColumn>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="X" 
                            Click="ButtonDeleteInstrument_Click"
                            Background="Transparent"
                            Foreground="#D32F2F"
                            BorderThickness="0"
                            FontWeight="Bold"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <TextBox x:Name="TB_Name" GotFocus="TB_Name_GotFocus" LostFocus="TB_Name_LostFocus"
         Width="470" Height="30"
         Background="White"
         Foreground="#424242"
         FontSize="14"
         Padding="5"
         BorderThickness="0"
         Text="Название" Margin="50,0,280,88" VerticalAlignment="Bottom"/>

        <TextBox x:Name="TB_Category" GotFocus="TB_Category_GotFocus" LostFocus="TB_Category_LostFocus"
         Width="150" Height="30"
         Background="White"
         Foreground="#424242"
         FontSize="14"
         Padding="5"
         BorderThickness="0"
         Margin="50,451,600,0"
         Text="Категория" VerticalAlignment="Top"/>

        <TextBox x:Name="TB_Type" GotFocus="TB_Type_GotFocus" LostFocus="TB_Type_LostFocus"
         Width="150" Height="30"
         Background="White"
         Foreground="#424242"
         FontSize="14"
         Padding="5"
         BorderThickness="0"
         Margin="210,451,440,0"
         Text="Тип инструмента" VerticalAlignment="Top"/>

        <TextBox x:Name="TB_Index" GotFocus="TB_Index_GotFocus" LostFocus="TB_Index_LostFocus"
         Width="150" Height="30"
         Background="White"
         Foreground="#424242"
         FontSize="14"
         Padding="5"
         BorderThickness="0"
         Margin="370,451,280,0"
         Text="Инвентарный номер" VerticalAlignment="Top"/>

        <Button x:Name="BT_AddInstrument" Click="AddInstrument_Click" Content="ДОБАВИТЬ" FontWeight="Bold" Margin="605,416,45,0" Height="30" Width="150" Background="red" VerticalAlignment="Top"></Button>
        <Button x:Name="BT_EditInstrument" Click="EditInstrument_Click" Content="ИЗМЕНИТЬ" FontWeight="Bold" Margin="605,451,45,0" Height="30" Width="150" VerticalAlignment="Top"></Button>




        <Image Source="C:\Users\user\source\repos\APP_WPF_InstrumentControl\obj\Assets\аварийная лента.png" VerticalAlignment="Bottom" HorizontalAlignment="Center" Height="25" Width="850"  ></Image>
    </Grid>
</Window>
